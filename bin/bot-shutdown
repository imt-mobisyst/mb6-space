#!/usr/bin/python3
import sys, subprocess

if len(sys.argv) < 2 :
    print( "send need the target machine name as argument..." )
    exit(1)

machine_name= sys.argv[1]

cmd= f'export ROS_DOMAIN_ID=140 ; ros2 topic pub -t 1 -w 0 /{machine_name}/command std_msgs/msg/String "data: \'shutdown\'"'
print(cmd)
subprocess.run(cmd, shell=True )
